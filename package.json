{
  "name": "trainers-web-plus",
  "description": "Trainers Web Plus Browser Extension",
  "license": "MIT",
  "version": "0.2.2",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:watch": "pnpm exec chokidar 'entrypoints/**/*' 'public/**/*' 'assets/**/*' --command \"pnpm wxt prepare && pnpm run build\"",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "preact": "^10.29.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@wxt-dev/module-react": "^1.1.5",
    "autoprefixer": "^10.5.2",
    "chokidar": "^5.0.0",
    "chokidar-cli": "^3.0.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "wxt": "^0.20.27"
  },
  "packageManager": "pnpm@10.33.0"
}
